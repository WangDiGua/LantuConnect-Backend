# 复制为项目根目录的 .env 后填写真实值（.env 已 .gitignore，勿提交）
#
# Spring Boot 不会自动加载本文件：请在运行前由 Docker Compose / shell export / IDE 注入同名环境变量。
# docker-compose 会从项目根目录读取 .env，用于 compose 内 ${VAR} 替换。
#
# 本地开发：将 application-local.example.yml 复制为 application-local.yml 并填写（主配置仅占位无默认值）。
# Compose：`docker-compose.yml` 已为 app 注入与 application.yml 对齐的全套占位变量；此处为可覆写的常用键。

# --- MySQL（docker-compose / 与 application.yml 默认约定）---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lantu_connect
DB_USER=lantu
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# --- Docker / 生产建议显式设置（Compose 内对未列出的键有开发向默认值，生产请改）---
# JWT_SECRET=
# JWT_ACCESS_TOKEN_EXPIRY=7200
# JWT_REFRESH_TOKEN_EXPIRY=604800
# LANTU_ENCRYPTION_KEY=
# LANTU_SECURITY_ENCRYPTION_KEY=
# LANTU_SYSTEM_INTEGRATION_MOCK=true
# FILE_UPLOAD_DIR=/tmp/lantu-connect-uploads
# SPRING_PROFILES_ACTIVE=dev
# PERMIT_PROMETHEUS_WITHOUT_AUTH=false
