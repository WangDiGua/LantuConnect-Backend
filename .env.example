# 复制为项目根目录的 .env 后填写真实值（.env 已 .gitignore，勿提交）
#
# Spring Boot 不会自动加载本文件：请在运行前由 Docker Compose / shell export / IDE 注入同名环境变量。
# docker-compose 会从项目根目录读取 .env，用于 compose 内 ${VAR} 替换。
#
# 本地开发更推荐：复制 src/main/resources/application-database.example.yml 为 application-database.yml
# 在 YAML 里直接改库/Redis 等（与 application.yml 占位默认值对应，见该模板）。

# --- MySQL（与 application.yml、docker-compose 一致）---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lantu_connect
DB_USER=lantu
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
# 裸跑 JAR 且不用消息队列时可不设或 false（与 application.yml 默认一致）；docker-compose 内默认 true
# RABBITMQ_LISTENER_AUTO_STARTUP=false

# --- 可选（不设置则使用 application.yml 占位；生产务必注入）---
# JWT_SECRET=
# LANTU_ENCRYPTION_KEY=
# FIELD_ENCRYPTION_KEY=
# SPRING_PROFILES_ACTIVE=dev
# PERMIT_PROMETHEUS_WITHOUT_AUTH=false
